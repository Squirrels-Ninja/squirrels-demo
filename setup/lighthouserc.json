{
  "$schema": "https://raw.githubusercontent.com/GoogleChrome/lighthouse-ci/v0.14.0/docs/configuration.json",
  "ci": {
    "collect": {
      "url": [
        "https://demo.squirrels.ninja/",
        "https://demo.squirrels.ninja/shop/",
        "https://demo.squirrels.ninja/cart/",
        "https://demo.squirrels.ninja/checkout/",
        "https://demo.squirrels.ninja/blog/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "formFactor": "desktop",
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1,
          "requestLatencyMs": 0,
          "downloadThroughputKbps": 10240,
          "uploadThroughputKbps": 10240
        },
        "screenEmulation": {
          "mobile": false,
          "width": 1350,
          "height": 940,
          "deviceScaleFactor": 1,
          "disabled": false
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["warn",  {"minScore": 0.70}],
        "categories:accessibility":   ["error", {"minScore": 0.90}],
        "categories:best-practices":  ["warn",  {"minScore": 0.80}],
        "categories:seo":             ["warn",  {"minScore": 0.80}],

        "first-contentful-paint":     ["warn",  {"maxNumericValue": 2000}],
        "largest-contentful-paint":   ["warn",  {"maxNumericValue": 3500}],
        "total-blocking-time":        ["warn",  {"maxNumericValue": 500}],
        "cumulative-layout-shift":    ["warn",  {"maxNumericValue": 0.1}],
        "interactive":                ["warn",  {"maxNumericValue": 4000}],

        "uses-responsive-images":     ["warn",  {}],
        "uses-webp-images":           ["warn",  {}],
        "efficient-animated-content": ["warn",  {}],
        "render-blocking-resources":  ["warn",  {}],
        "unused-css-rules":           ["warn",  {}],
        "unused-javascript":          ["warn",  {}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
